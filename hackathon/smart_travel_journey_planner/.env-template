GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_PROJECT=train-commutor-productivity-assistant
GOOGLE_CLOUD_LOCATION=global

SERVICE_ACCOUNT=deployed-sa@train-commutor-productivity-assistant.iam.gserviceaccount.com
SERVICE_ID=deployed-sa

TRAIN_DATA_MCP_URL=https://railway-mcp.amithv.xyz/mcp

# Workspace MCP Configuration
WORKSPACE_MCP_URL=
WORKSPACE_MCP_COMMAND=uvx
WORKSPACE_MCP_ARGS=workspace-mcp --tool-tier core

# Google OAuth Credentials (Required for Workspace MCP)
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
USER_GOOGLE_EMAIL=email
OAUTHLIB_INSECURE_TRANSPORT=1
MCP_SINGLE_USER_MODE=true