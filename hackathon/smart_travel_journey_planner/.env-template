GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_PROJECT=train-commutor-productivity-assistant
GOOGLE_CLOUD_LOCATION=global

SERVICE_ACCOUNT=deployed-sa@train-commutor-productivity-assistant.iam.gserviceaccount.com
SERVICE_ID=deployed-sa

TRAIN_DATA_MCP_URL=https://railway-mcp.amithv.xyz/mcp

# Workspace MCP Configuration
# workspace-mcp runs as a local HTTP server (--transport streamable-http).
# EXTERNAL_OAUTH21_PROVIDER=true tells workspace-mcp our app handles OAuth —
# it validates the Bearer access_token we pass per-request, giving true multi-user isolation.
WORKSPACE_MCP_URL=
WORKSPACE_MCP_COMMAND=workspace-mcp
WORKSPACE_MCP_ARGS=--tool-tier extended
WORKSPACE_MCP_HTTP_PORT=8765
EXTERNAL_OAUTH21_PROVIDER=true

# Google OAuth Credentials (Required for login + Workspace MCP)
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# OAuth redirect URI
# Local dev: leave commented — auto-detected from request URL
# Cloud Run: set to https://<YOUR-SERVICE>.a.run.app/auth/callback
# GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/auth/callback

# Local dev only — allows OAuth over http:// (set automatically in code)
OAUTHLIB_INSECURE_TRANSPORT=1

# Optional: fallback email for /dev/test-confirm only
# USER_GOOGLE_EMAIL=you@gmail.com